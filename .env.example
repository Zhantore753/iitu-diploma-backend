# Copy to .env for local development. On Railway, set these in the
# service "Variables" tab. DATABASE_URL and REDIS_URL are provided
# automatically when you reference the Postgres/Redis plugins.

# --- Provided automatically by Railway plugins (reference, don't hardcode) ---
# DATABASE_URL is injected by the Postgres plugin.
# REDIS_URL is injected by the Redis plugin.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/agri_rental
REDIS_URL=redis://localhost:6380

# --- Local-only Redis fallback (ignored when REDIS_URL is set) ---
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=
REDIS_DB=0

# --- Cache TTLs (optional) ---
REDIS_MEMORY_TTL=6000
CACHE_REDIS_TTL=3600000

# --- App ---
NODE_ENV=production
PORT=3000

# --- JWT (generate strong random secrets!) ---
JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me
JWT_SECRET_EXP=15m
JWT_REFRESH_SECRET_EXP=7d

# --- OTP / sessions ---
OTP_EXPIRY_MINUTES=5
REGISTRATION_SESSION_MINUTES=15

# --- Refresh tokens ---
REFRESH_TOKEN_COOKIE_NAME=refresh_token
REFRESH_TOKEN_MAX_SESSIONS=5

# --- Default admin bootstrap ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...
